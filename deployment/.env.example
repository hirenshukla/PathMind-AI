# Copy this file to deployment/.env before running docker compose.
# Use strong secrets. Do not commit deployment/.env.

# Domains
APP_DOMAIN=pathmind.ai
WWW_DOMAIN=www.pathmind.ai
API_DOMAIN=api.pathmind.ai
LETSENCRYPT_EMAIL=ops@pathmind.ai

# Frontend build-time API base URL
# Use https://api.yourdomain.com/api/v1 or /api/v1 (same-origin via reverse proxy).
NEXT_PUBLIC_API_URL=https://api.pathmind.ai/api/v1

# Runtime environment
ENVIRONMENT=production
DEBUG=false

# Database (PostgreSQL)
POSTGRES_DB=pathmind_db
POSTGRES_USER=pathmind_user
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
# If your DB password has special characters, URL-encode it in DATABASE_URL.
DATABASE_URL=postgresql+asyncpg://pathmind_user:CHANGE_ME_TO_A_STRONG_PASSWORD@postgres:5432/pathmind_db

# JWT auth (minimum 32 chars, 64+ recommended)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Security allow-lists
CORS_ORIGINS=https://pathmind.ai,https://www.pathmind.ai,https://app.pathmind.ai
# Optional regex for dynamic preview domains (example: Vercel previews)
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
TRUSTED_HOSTS=pathmind.ai,www.pathmind.ai,api.pathmind.ai,app.pathmind.ai
FRONTEND_URL=https://pathmind.ai

# Optional integrations
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# SENDGRID_API_KEY=
# DATA_GOV_IN_API_KEY=
