# PathMind AI Backend — Environment Template
# ============================================
# Copy this file to backend/.env and update values.
# NEVER commit the actual .env file to git.

ENVIRONMENT=development
DEBUG=true

# Database
# For development (SQLite):
# DATABASE_URL=sqlite+aiosqlite:///pathmind.db
# For production (PostgreSQL):
DATABASE_URL=postgresql+asyncpg://pathmind_user:CHANGE_THIS_PASSWORD@localhost:5432/pathmind_db

# JWT — IMPORTANT: Generate a strong random secret for production
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional regex for dynamic frontend hosts (example: Vercel preview URLs)
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app
TRUSTED_HOSTS=localhost,127.0.0.1,*.localhost,*
FRONTEND_URL=http://localhost:3000

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SendGrid Email
SENDGRID_API_KEY=

# data.gov.in API (Real Government Data Integration)
DATA_GOV_IN_API_KEY=
# Optional custom resource IDs (defaults are preconfigured in code)
# DATA_GOV_IN_JOBS_STATE_RESOURCE_ID=
# DATA_GOV_IN_JOBS_SECTOR_RESOURCE_ID=
# DATA_GOV_IN_EDUCATION_RESOURCE_ID=
# DATA_GOV_IN_EMPLOYMENT_RESOURCE_ID=
# DATA_GOV_IN_EXAM_RESOURCE_ID=
